# Copy to .env for local dev (with `vercel dev`). In production, set these in
# Vercel → Project → Settings → Environment Variables instead.

# Neon Postgres connection string (Neon dashboard → Connection Details → pooled).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Secret used to sign session tokens. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string"
