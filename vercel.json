{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/handler?p=:path*" }
  ],
  "crons": [
    { "path": "/api/cron/stock-snapshot", "schedule": "0 2 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(js|css|html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ]
}
